rules_version = '2';
service cloudfirestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Trips endpoints
    match /trips/{tripId} {
      allow get: if isSignedIn() && isOwner(existing());
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(tripId) && isValidTrip(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isValidId(tripId) && isOwner(existing()) && isValidTrip(incoming()) && incoming().updatedAt == request.time && incoming().createdAt == existing().createdAt && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && isOwner(existing());
    }

    // GLOBAL SAFETY HELPERS
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(resData) {
      return resData.userId == request.auth.uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidTrip(data) {
      return data.keys().hasAll(['title', 'startDate', 'endDate', 'userId', 'schedule', 'createdAt', 'updatedAt'])
        && data.keys().size() == 7
        && data.title is string && data.title.size() <= 150
        && data.description is string && data.description.size() <= 1000
        && data.startDate is string && data.startDate.size() <= 15
        && data.endDate is string && data.endDate.size() <= 15
        && data.userId is string && data.userId == request.auth.uid
        && data.schedule is map;
    }
  }
}
